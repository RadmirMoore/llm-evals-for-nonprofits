# Copy this file to `.env` and fill in your key:
#   cp .env.example .env
#
# `.env` is gitignored and is NEVER committed. Each user supplies their own key.
# Only needed for the live/judge modes; the offline suite runs without it.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model overrides (defaults shown):
# EVAL_MODEL=claude-sonnet-4-5
# EVAL_JUDGE_MODEL=claude-sonnet-4-5
